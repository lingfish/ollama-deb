#!/usr/bin/make -f

# See debhelper(7) (uncomment to enable).
# Output every command that modifies files on the build system.
export DH_VERBOSE = 1


# See FEATURE AREAS in dpkg-buildflags(1).
#export DEB_BUILD_MAINT_OPTIONS = hardening=+all

# See ENVIRONMENT in dpkg-buildflags(1).
# Package maintainers to append CFLAGS.
#export DEB_CFLAGS_MAINT_APPEND  = -Wall -pedantic
# Package maintainers to append LDFLAGS.
#export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed


%:
	dh $@ --with sysuser


# dh_make generated override targets.
# This is an example for Cmake (see <https://bugs.debian.org/641051>).
#override_dh_auto_configure:
#       dh_auto_configure -- \
#       -DCMAKE_LIBRARY_PATH=$(DEB_HOST_MULTIARCH)

# Don't run strip
override_dh_strip:

# Build different packages for different architectures
override_dh_auto_build:
	@echo "Building AMD64 package..."
	cd .. && dpkg-buildpackage -b -us -uc -aamd64
	@echo "Building ARM64 package..."
	cd .. && cd ollama-${VERSION_NO_V}/tmp-arm64 && \
	  cp -r /home/runner/work/ollama-deb/packaging_files/* debian/ && \
	  sed -i 's/Architecture: amd64/Architecture: arm64/' debian/control && \
	  dpkg-buildpackage -b -us -uc -aarm64
	@echo "Building ARM64 JetPack 5 package..."
	cd .. && cd ollama-${VERSION_NO_V}/tmp-arm64-jetpack5 && \
	  cp -r /home/runner/work/ollama-deb/packaging_files/* debian/ && \
	  sed -i 's/Architecture: amd64/Architecture: arm64/' debian/control && \
	  dpkg-buildpackage -b -us -uc -aarm64
	@echo "Building ARM64 JetPack 6 package..."
	cd .. && cd ollama-${VERSION_NO_V}/tmp-arm64-jetpack6 && \
	  cp -r /home/runner/work/ollama-deb/packaging_files/* debian/ && \
	  sed -i 's/Architecture: amd64/Architecture: arm64/' debian/control && \
	  dpkg-buildpackage -b -us -uc -aarm64
	@echo "All architectures built successfully!"
